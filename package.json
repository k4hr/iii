{
  "name": "theoryforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "railway:start": "prisma db push --accept-data-loss && prisma generate && next start -H 0.0.0.0 -p ${PORT:-3000}"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "animejs": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "next": "^15.4.0",
    "next-intl": "^3.26.5",
    "openai": "^6.42.0",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
