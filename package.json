    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "animejs": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "next": "^15.4.0",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^3.26.5",
    "openai": "^6.42.0",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
